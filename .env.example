# ===========================================
# CONFIGURAÇÃO DO AMBIENTE - SISTEMA DE BANCO DE TALENTOS
# ===========================================
# Copie este arquivo para .env e ajuste os valores conforme necessário

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DB_NAME=talent_bank
DB_USER=postgres
DB_PASSWORD=postgres_secure_password_123
DB_HOST=localhost
DB_PORT=5432

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_123

# ===========================================
# MINIO/S3 CONFIGURATION
# ===========================================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin_secure_password_123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET_NAME=talent-bank-files
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin_secure_password_123

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
BACKEND_PORT=8080
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Spring Profile
SPRING_PROFILES_ACTIVE=development

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# IMPORTANTE: Gere uma chave segura para produção
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-make-it-long
JWT_EXPIRATION=86400000

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
# Escolha um provedor: smtp, postmark, ses
MAIL_PROVIDER=smtp

# ---- SMTP Configuration (Gmail, Outlook, etc.) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@empresa.com

# Spring Mail (used by JavaMailSender)
MAIL_USERNAME=
MAIL_PASSWORD=

# ---- Postmark Configuration ----
POSTMARK_API_TOKEN=your-postmark-server-token
POSTMARK_FROM=noreply@empresa.com

# ---- Amazon SES Configuration ----
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
SES_FROM=noreply@empresa.com

# ===========================================
# WHATSAPP CONFIGURATION
# ===========================================
# Escolha um provedor: meta, twilio
WHATSAPP_PROVIDER=meta

# ---- Meta WhatsApp Cloud API ----
META_WHATSAPP_ACCESS_TOKEN=your-meta-access-token
META_WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
META_WHATSAPP_BUSINESS_PHONE=+5585999999999

# ---- Twilio Configuration ----
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ===========================================
# LINKEDIN INTEGRATION (OPCIONAL)
# ===========================================
# Para importação via LinkedIn Recruiter API
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ===========================================
# JESTOR INTEGRATION
# ===========================================
JESTOR_API_URL=https://your-namespace.api.jestor.com
JESTOR_API_TOKEN=your-jestor-api-token
JESTOR_SYNC_CRON=0 */30 * * * *
JESTOR_JOBS_TABLE=your-jobs-table-id
JESTOR_CLIENTS_TABLE=your-clients-table-id
JESTOR_CANDIDATES_TABLE=your-candidates-table-id
JESTOR_HEADHUNTERS_TABLE=your-headhunters-table-id
JESTOR_MOVEMENTS_TABLE=your-movements-table-id
JESTOR_WARRANTIES_TABLE=your-warranties-table-id

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/application.log

# ===========================================
# DESENVOLVIMENTO - CONFIGURAÇÕES ESPECÍFICAS
# ===========================================
# Habilitar/desabilitar recursos em desenvolvimento
ENABLE_SWAGGER=true
ENABLE_ACTUATOR=true
ENABLE_CORS=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# PRODUÇÃO - CONFIGURAÇÕES ESPECÍFICAS
# ===========================================
# Para ambiente de produção, ajuste:
# SPRING_PROFILES_ACTIVE=production
# ENABLE_SWAGGER=false
# CORS_ALLOWED_ORIGINS=https://app.empresa.com
# Use senhas fortes e diferentes para cada serviço
# Configure SSL/TLS appropriadamente

# ===========================================
# MONITORING & OBSERVABILITY (OPCIONAL)
# ===========================================
# SENTRY_DSN=your-sentry-dsn
# NEWRELIC_LICENSE_KEY=your-newrelic-key
# DATADOG_API_KEY=your-datadog-key

# ===========================================
# BACKUP CONFIGURATION (OPCIONAL)
# ===========================================
# BACKUP_S3_BUCKET=talent-bank-backups
# BACKUP_SCHEDULE=0 2 * * *  # Diário às 2h
# BACKUP_RETENTION_DAYS=30